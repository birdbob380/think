<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Think Flamnet | Industrial 3D Solutions</title>
  <style>
    :root {
      --primary: #00cfcc; 
      --secondary: #7000ff; 
      --bg: #0f172a; 
      --card-bg: #1e293b;
      --text: #f8fafc;
      --text-muted: #94a3b8;
      --border: #334155;
      --accent-grad: linear-gradient(135deg, var(--primary), var(--secondary));
      --glass: rgba(30, 41, 59, 0.7);
    }

    * { box-sizing: border-box; transition: all 0.3s ease; }
    
    body {
      margin: 0;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--text);
      background: var(--bg);
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* --- Navigation --- */
    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 8%;
      background: rgba(15, 23, 42, 0.8);
      backdrop-filter: blur(15px);
      position: sticky;
      top: 0;
      z-index: 1000;
      border-bottom: 1px solid var(--border);
    }

    .logo-container { display: flex; align-items: center; gap: 12px; cursor: pointer; }
    .logo-icon { 
        width: 32px; height: 32px; 
        background: var(--accent-grad); 
        border-radius: 8px;
        box-shadow: 0 0 15px rgba(0, 207, 204, 0.3);
    }
    .logo-text { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.5px; }

    nav { display: flex; align-items: center; gap: 30px; }
    nav a {
      text-decoration: none;
      color: var(--text-muted);
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
    }
    nav a:hover { color: var(--primary); }
    
    .cart-btn { 
        background: rgba(255,255,255,0.05); 
        padding: 10px 20px; 
        border-radius: 12px; 
        border: 1px solid var(--border);
        color: var(--text) !important;
    }
    .cart-btn:hover { background: var(--primary); color: white !important; border-color: var(--primary); }

    /* --- Hero Section --- */
    .hero-banner {
      padding: 120px 20px;
      text-align: center;
      background: radial-gradient(circle at 50% -20%, rgba(112, 0, 255, 0.2), transparent);
    }
    .hero-banner h1 { font-size: 4rem; margin: 0; letter-spacing: -2px; line-height: 1; }
    .hero-banner p { font-size: 1.25rem; color: var(--text-muted); max-width: 650px; margin: 25px auto; }
    
    .cta-button {
        display: inline-block; padding: 18px 45px; 
        background: var(--accent-grad);
        border-radius: 12px; text-decoration: none; 
        color: white; font-weight: bold; cursor: pointer;
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }
    .cta-button:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(112, 0, 255, 0.3); }

    /* --- Features --- */
    .features-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
      max-width: 1200px;
      margin: -60px auto 60px;
      padding: 0 20px;
    }
    .feature-card {
      background: var(--card-bg);
      padding: 30px;
      border-radius: 20px;
      border: 1px solid var(--border);
      backdrop-filter: blur(10px);
    }

    /* --- Catalog & Cards --- */
    .grid { 
        max-width: 1200px; margin: 40px auto; padding: 0 20px; 
        display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 25px; 
    }
    
    .card {
      background: var(--glass);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 24px;
      display: flex; flex-direction: column;
      position: relative;
    }
    .card:hover { border-color: var(--primary); transform: translateY(-8px); }
    
    .card-img { 
        height: 200px; background: #0a0f1d; border-radius: 16px; 
        margin-bottom: 20px; display: flex; align-items: center; 
        justify-content: center; font-size: 4rem; 
    }
    
    button {
        width: 100%; padding: 14px; border-radius: 12px; border: none;
        background: rgba(255,255,255,0.05); color: white;
        font-weight: 600; cursor: pointer; border: 1px solid var(--border);
    }
    button:hover { background: var(--primary); border-color: var(--primary); }

    .price-tag { font-size: 1.5rem; font-weight: 700; color: var(--text); margin: 10px 0 20px; }
    .stock-status { font-size: 0.7rem; letter-spacing: 1px; font-weight: 700; margin-bottom: 8px; }

    /* --- Page States --- */
    #cart, #confirmation { display: none; }
    
    .container-small { max-width: 800px; margin: 60px auto; padding: 40px; }

    /* --- Cart Styling --- */
    .cart-item { 
        display: flex; justify-content: space-between; align-items: center;
        padding: 20px 0; border-bottom: 1px solid var(--border); 
    }
    .summary-box {
        background: rgba(255,255,255,0.02); padding: 30px; 
        border-radius: 20px; margin-top: 30px; border: 1px solid var(--border);
    }
    .summary-line { display: flex; justify-content: space-between; margin-bottom: 10px; color: var(--text-muted); }
    .total-line { font-size: 1.4rem; font-weight: 800; color: var(--primary); margin-top: 15px; border-top: 1px solid var(--border); pt: 15px; }

    /* --- Toasts --- */
    #toast-container { position: fixed; bottom: 30px; right: 30px; z-index: 9999; }
    .toast {
      background: var(--card-bg); border: 1px solid var(--primary); color: white; 
      padding: 16px 24px; border-radius: 12px; margin-top: 10px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.4);
      animation: slideIn 0.3s ease-out forwards;
    }
    @keyframes slideIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    footer { background: #050811; padding: 80px 20px; border-top: 1px solid var(--border); margin-top: 100px; }
  </style>
</head>
<body>

<header>
  <div class="logo-container" onclick="showHome()">
    <div class="logo-icon"></div>
    <div class="logo-text">FLAMNET</div>
  </div>
  <nav>
    <a onclick="showHome()">Shop</a>
    <a onclick="showFilament()">Filaments</a>
    <a onclick="showPrinters()">Hardware</a>
    <a onclick="showCart()" class="cart-btn">🛒 <span id="cartCount">0</span> Items</a>
  </nav>
</header>

<div id="home">
  <section class="hero-banner">
    <h1>Industrial 3D <span style="color:var(--primary)">Evolved.</span></h1>
    <p>Premium filaments and industrial-grade hardware for engineers who demand precision and reliability.</p>
    <div class="cta-button" onclick="window.scrollTo({top: 700, behavior: 'smooth'})">View Inventory</div>
  </section>

  <section class="features-row">
    <div class="feature-card"><h3>🚀 Fast Logistics</h3><p>Global priority shipping on all orders over $150.</p></div>
    <div class="feature-card"><h3>🛡️ Pro Support</h3><p>2-year comprehensive warranty and 24/7 tech assist.</p></div>
    <div class="feature-card"><h3>🧪 Lab Grade</h3><p>Verified diameter consistency within +/- 0.02mm.</p></div>
  </section>

  <div id="products" class="grid">
    <div class="card filament">
      <div class="stock-status" style="color: #10b981">● IN STOCK</div>
      <div class="card-img">🧵</div>
      <h3>PLA Brainwave</h3>
      <p style="color:var(--text-muted); font-size:0.85rem">Premium biodegradable polymer for rapid prototyping.</p>
      <div class="price-tag">$24.99</div>
      <button onclick="addToCart('PLA Brainwave', 24.99)">Add to Cart</button>
    </div>

    <div class="card filament">
        <div class="stock-status" style="color: #10b981">● IN STOCK</div>
        <div class="card-img">🧵</div>
        <h3>PETG LavaFlex</h3>
        <p style="color:var(--text-muted); font-size:0.85rem">High-strength material with superior thermal resistance.</p>
        <div class="price-tag">$31.50</div>
        <button onclick="addToCart('PETG LavaFlex', 31.50)">Add to Cart</button>
      </div>

    <div class="card printer">
      <div class="stock-status" style="color:var(--primary)">● LOW STOCK</div>
      <div class="card-img">🖨️</div>
      <h3>Flamnet MK‑Zero</h3>
      <p style="color:var(--text-muted); font-size:0.85rem">Compact industrial powerhouse for high-detail parts.</p>
      <div class="price-tag">$399.00</div>
      <button onclick="addToCart('Flamnet MK‑Zero', 399.00)">Add to Cart</button>
    </div>

    <div class="card printer">
        <div class="stock-status" style="color: #10b981">● IN STOCK</div>
        <div class="card-img">🖨️</div>
        <h3>Flamnet Studio S2</h3>
        <p style="color:var(--text-muted); font-size:0.85rem">Dual-extrusion system for complex industrial geometry.</p>
        <div class="price-tag">$749.00</div>
        <button onclick="addToCart('Flamnet Studio S2', 749.00)">Add to Cart</button>
      </div>
  </div>
</div>

<div id="cart" class="container-small">
  <h2 style="font-size: 2rem; margin-bottom: 10px;">Your Cart</h2>
  <p style="color:var(--text-muted); margin-bottom: 40px;">Review your items before proceeding to secure checkout.</p>
  
  <div id="cartItems"></div>
  
  <div class="summary-box">
    <div class="summary-line"><span>Subtotal</span> <span id="subtotal">$0.00</span></div>
    <div class="summary-line"><span>Tax (10%)</span> <span id="tax">$0.00</span></div>
    <div class="summary-line"><span>Shipping</span> <span id="shipping">$0.00</span></div>
    <div class="summary-line total-line"><span>Total</span> <span id="total">$0.00</span></div>
    <button style="margin-top: 30px; background: var(--accent-grad); padding: 20px;" onclick="checkout()">Complete Purchase</button>
  </div>
  <p style="text-align:center; margin-top:20px"><a onclick="showHome()" style="color:var(--text-muted); cursor:pointer; text-decoration: none;">← Continue Shopping</a></p>
</div>

<div id="confirmation" class="container-small" style="text-align: center;">
    <div style="font-size: 80px; margin-bottom: 20px;">✅</div>
    <h2 style="font-size: 2.5rem;">Order Confirmed</h2>
    <p style="color:var(--text-muted); font-size: 1.1rem;">Thank you for choosing Flamnet. Your industrial supplies are being prepared for dispatch.</p>
    <div style="background: rgba(255,255,255,0.05); padding: 20px; border-radius: 12px; margin: 30px 0;">
        <strong>Order ID: #FLAM-98231</strong>
    </div>
    <button onclick="showHome()" style="width:auto; padding: 15px 40px;">Back to Shop</button>
</div>

<div id="toast-container"></div>

<footer>
  <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 40px;">
    <div>
      <div class="logo-text" style="margin-bottom:20px">FLAMNET</div>
      <p style="color:var(--text-muted); font-size: 0.9rem;">The leading provider of additive manufacturing materials for the aerospace and automotive sectors.</p>
    </div>
    <div style="color: var(--text-muted); font-size: 0.9rem;">
        <h4 style="color: white; margin-bottom: 15px;">Resources</h4>
        <div style="margin-bottom: 8px;">Technical Data Sheets</div>
        <div style="margin-bottom: 8px;">Safety Compliance</div>
        <div style="margin-bottom: 8px;">Firmware Updates</div>
    </div>
    <div>
      <h4 style="color: white; margin-bottom: 15px;">Newsletter</h4>
      <input type="email" placeholder="Enter email" style="width:100%; padding:12px; background:#1e293b; border:1px solid #334155; border-radius:8px; color:white; margin-bottom:10px;">
      <button style="width: auto; padding: 10px 25px;">Join</button>
    </div>
  </div>
</footer>

<script>
let cart = [];

function navigate(pageId) {
    // Hide all pages
    document.getElementById('home').style.display = 'none';
    document.getElementById('cart').style.display = 'none';
    document.getElementById('confirmation').style.display = 'none';
    
    // Show target page
    document.getElementById(pageId).style.display = 'block';
    window.scrollTo(0,0);
}

function showHome() {
    navigate('home');
    document.querySelectorAll('.filament, .printer').forEach(c => c.style.display = 'flex');
}

function showFilament() {
    showHome();
    document.querySelectorAll('.printer').forEach(c => c.style.display = 'none');
}

function showPrinters() {
    showHome();
    document.querySelectorAll('.filament').forEach(c => c.style.display = 'none');
}

function showCart() {
    navigate('cart');
    renderCart();
}

function addToCart(name, price) {
    const existing = cart.find(i => i.name === name);
    existing ? existing.qty++ : cart.push({ name, price, qty: 1 });
    updateUI();
    showToast(name);
}

function removeFromCart(name) {
    cart = cart.filter(i => i.name !== name);
    updateUI();
    renderCart();
}

function updateUI() {
    const count = cart.reduce((acc, i) => acc + i.qty, 0);
    document.getElementById('cartCount').textContent = count;
}

function showToast(name) {
    const container = document.getElementById('toast-container');
    const toast = document.createElement('div');
    toast.className = 'toast';
    toast.innerHTML = `<strong>Added to Session</strong><br><small>${name}</small>`;
    container.appendChild(toast);
    setTimeout(() => {
        toast.style.opacity = '0';
        setTimeout(() => toast.remove(), 500);
    }, 2500);
}

function renderCart() {
    const container = document.getElementById('cartItems');
    if (cart.length === 0) {
        container.innerHTML = '<p style="text-align:center; padding: 40px; color: var(--text-muted);">Your cart is empty.</p>';
    } else {
        container.innerHTML = cart.map(i => `
            <div class="cart-item">
                <div>
                    <div style="font-weight:bold">${i.name}</div>
                    <div style="color:var(--text-muted); font-size:0.8rem">Quantity: ${i.qty}</div>
                </div>
                <div style="text-align:right">
                    <div style="font-weight:bold">$${(i.price * i.qty).toFixed(2)}</div>
                    <div style="color:#f87171; font-size:0.75rem; cursor:pointer" onclick="removeFromCart('${i.name}')">Remove</div>
                </div>
            </div>
        `).join('');
    }

    let sub = cart.reduce((acc, i) => acc + (i.price * i.qty), 0);
    let tax = sub * 0.10;
    let ship = sub > 150 || sub === 0 ? 0 : 15.00;

    document.getElementById('subtotal').textContent = `$${sub.toFixed(2)}`;
    document.getElementById('tax').textContent = `$${tax.toFixed(2)}`;
    document.getElementById('shipping').textContent = ship === 0 ? 'FREE' : `$${ship.toFixed(2)}`;
    document.getElementById('total').textContent = `$${(sub + tax + ship).toFixed(2)}`;
}

function checkout() {
    if(cart.length === 0) return alert("Your cart is empty");
    cart = [];
    updateUI();
    navigate('confirmation');
}
</script>

</body>
</html>
